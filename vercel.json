{
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/info",
      "permanent": false
    },
    {
      "source": "/api",
      "destination": "/info",
      "permanent": false
    },
    {
      "source": "/health",
      "destination": "/info",
      "permanent": false
    }
  ]
}
