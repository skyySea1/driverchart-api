{
  "compilerOptions": { 
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ]
    },
    "target": "esnext",
    "module": "CommonJS", 
    "outDir": "./dist", 
    "moduleResolution": "node", 
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true, 
    "strict": true, 
        "skipLibCheck": true
      },
      "include": ["src/**/*", "api/**/*"]
    }
    